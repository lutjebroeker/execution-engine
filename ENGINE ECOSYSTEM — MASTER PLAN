-- =====================
-- SEMANTIC SEARCH FUNCTIONS
-- =====================
create or replace function search_knowledge(
  p_tenant_id uuid,
  query_embedding vector(1536),
  match_threshold float default 0.7,
  match_count int default 5
)
returns table (id uuid, title text, content text, source_url text, similarity float)
language sql stable as $$
  select id, title, content, source_url,
    1 - (embedding <=> query_embedding) as similarity
  from knowledge
  where tenant_id = p_tenant_id
    and 1 - (embedding <=> query_embedding) > match_threshold
  order by embedding <=> query_embedding
  limit match_count;
$$;

create or replace function search_memory(
  p_tenant_id uuid,
  query_embedding vector(1536),
  match_threshold float default 0.7,
  match_count int default 5
)
returns table (id uuid, category text, content text, tags text[], similarity float)
language sql stable as $$
  select id, category, content, tags,
    1 - (embedding <=> query_embedding) as similarity
  from memory
  where tenant_id = p_tenant_id
    and 1 - (embedding <=> query_embedding) > match_threshold
  order by embedding <=> query_embedding
  limit match_count;
$$;
```

### 10.5 n8n workflows

**Core (4 workflows):**

1. **Telegram Handler** — webhook, routes by chat_id → tenant_id, Claude API with tools, responds
2. **Morning Briefing** — cron 07:00, loops all active tenants, generates + sends personalized briefing
3. **Accountability Check-in** — cron 17:00, loops all active tenants, asks about today's priorities
4. **Weekly Review** — cron Sunday 18:00, generates execution score + patterns + sends

**Publish Engine (2 workflows — start here, add more later):**

5. **Draft Generation** — IE signal or manual trigger → Claude API → content_items
6. **Scheduled Publishing** — cron every 15 min → publishes approved items via Postiz or direct API

**Later additions:**
- IE scan (RSS + Ollama scoring) — when IE is running
- Engagement tracking — when 4+ weeks of posting data exists
- Self-learning aggregator — monthly, analyzes cross-client patterns → updates system_patterns table
- Telegram approval workflow — when publishing volume exceeds manual review

