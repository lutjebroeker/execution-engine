{
  "id": "2pafgxsVIs1E9RNQ",
  "name": "Execution Engine — Gumroad Purchase Welcome Email",
  "active": false,
  "nodes": [
    {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Gumroad Sale Ping",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "gumroad-sale",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "Respond 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [460, 200],
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK"
      }
    },
    {
      "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
      "name": "Extract Buyer Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 400],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "d1e2f3a4-b5c6-7890-abcd-ef1234567890",
              "name": "buyerEmail",
              "value": "={{$json.body.email}}",
              "type": "string"
            },
            {
              "id": "e2f3a4b5-c6d7-8901-bcde-f12345678901",
              "name": "productName",
              "value": "={{$json.body.product_name}}",
              "type": "string"
            },
            {
              "id": "f3a4b5c6-d7e8-9012-cdef-123456789012",
              "name": "orderNumber",
              "value": "={{$json.body.order_number}}",
              "type": "string"
            },
            {
              "id": "a4b5c6d7-e8f9-0123-defa-234567890123",
              "name": "licenseKey",
              "value": "={{$json.body.license_key}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "d4e5f6a7-b8c9-0123-efab-345678901234",
      "name": "Send Welcome Email via Resend",
