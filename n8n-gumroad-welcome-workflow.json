        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={\"from\": \"Jelle Spek <support@jellespek.nl>\", \"to\": [\"{{$json.buyerEmail}}\"], \"subject\": \"Your Execution Engine AM Bundle \u2014 Start Here\", \"html\": \"<div style='font-family:Georgia,serif;max-width:600px;margin:0 auto;padding:32px 24px;color:#1a1a1a;line-height:1.6'><h1 style='font-size:24px;margin-bottom:8px'>Welcome to Execution Engine</h1><p>You have everything you need to go from zero to your first Telegram check-in in 30 minutes.</p><h2 style='font-size:18px;margin-top:32px'>Start Here - Your Checklist</h2><ol style='padding-left:20px'><li>Open <strong>README.md</strong> in your bundle</li><li>Install prerequisites: n8n, Telegram, Obsidian, Ollama, PostgreSQL</li><li>Follow the 7-step setup guide from top to bottom</li><li>Activate your workflows in n8n</li><li>Send <strong>/start</strong> to your Telegram bot</li></ol><p style='margin-top:24px;padding:16px;background:#f5f5f0;border-radius:4px'>Your bundle download link is in your Gumroad receipt email. Cant find it? Visit <a href='https://app.gumroad.com/library' style='color:#1D4ED8'>app.gumroad.com/library</a></p><p>Questions? Email <a href='mailto:support@jellespek.nl' style='color:#1D4ED8'>support@jellespek.nl</a> - I reply within 24 hours.</p><p style='margin-top:32px'>- Jelle</p></div>\"}",
        "options": {}
      }
    }
  ],
  "connections": {
    "Gumroad Sale Ping": {
      "main": [
        [
          {"node": "Respond 200 OK", "type": "main", "index": 0},
          {"node": "Extract Buyer Data", "type": "main", "index": 0}
        ]
      ]
    },
    "Extract Buyer Data": {
      "main": [
        [
          {"node": "Send Welcome Email via Resend", "type": "main", "index": 0}
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
